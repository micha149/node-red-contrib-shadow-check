{
  "name": "@micha149/node-red-contrib-shadow-check",
  "version": "1.0.0",
  "description": "A Node-RED node for checking if the sun shines into a window",
  "main": "dist/nodes/shadow-check/shadow-check.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run build:runtime && npm run build:editor && npm run copy:assets",
    "build:runtime": "tsc -p tsconfig.json",
    "build:editor": "node scripts/build-editor.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "author": "micha149",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/micha149/node-red-contrib-shadow-check.git"
  },
  "bugs": {
    "url": "https://github.com/micha149/node-red-contrib-shadow-check/issues"
  },
  "homepage": "https://github.com/micha149/node-red-contrib-shadow-check#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "resources",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "node-red"
  ],
  "node-red": {
    "version": ">=4.0.0",
    "nodes": {
      "shadow-check": "dist/nodes/shadow-check/shadow-check.js"
    }
  },
  "dependencies": {
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
